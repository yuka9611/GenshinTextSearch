# Public base URL of the Flask API. Use HTTPS and omit the /api suffix.
VITE_AXIOS_BASE_URL=https://api.example.com/

# The 3 GB SQLite database can need more than five seconds for an uncached query.
VITE_API_TIMEOUT_MS=30000

# Supabase Auth and per-user preferences/search history. This is a public URL
# and publishable browser key; never place a secret/service-role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Enable only providers configured in Supabase Auth.
VITE_AUTH_PROVIDERS=github,google
